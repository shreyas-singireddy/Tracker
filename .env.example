# FitOS Environment Configuration
# Copy this file to .env and adjust values for your deployment.
# FitOS is designed to run fully offline — do not enable network features.

# Application Environment: development, testing, production
FITOS_ENV=development

# Offline Mode Enforcement (MUST be True for FitOS to operate)
OFFLINE_MODE=True

# Database Path (relative to project root)
DB_PATH=fitos.db

# Logging Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log File Path (relative to project root)
LOG_FILE=logs/fitos.log

# Debug Mode (automatically enabled in development/testing)
DEBUG=False

# Feature Flags
FEATURE_AI_COACH=True
FEATURE_ANALYTICS=True
FEATURE_REPORTS=True
